# Optional Spline 3D scenes (export from https://spline.design)
# Copy to .env.local and paste your scene URLs.

# One scene with all floating decor (recommended — single WebGL context)
# VITE_SPLINE_FLOAT_SCENE=https://prod.spline.design/YOUR_ID/scene.splinecode

# Or per-star scenes (CSS 3D stars used as fallback until each loads)
# VITE_SPLINE_STAR_BLUE=https://prod.spline.design/YOUR_BLUE_STAR/scene.splinecode
# VITE_SPLINE_STAR_GREEN=https://prod.spline.design/YOUR_GREEN_STAR/scene.splinecode
